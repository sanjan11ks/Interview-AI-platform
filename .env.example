# ─────────────────────────────────────────────────────────────
# Interview AI — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# Anthropic API key — OPTIONAL at deploy time.
# Leave blank. The admin can add it from the Settings tab after logging in.
# Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Server port (Railway sets this automatically)
PORT=3001

NODE_ENV=production

# Where to store uploaded files (leave as default)
UPLOAD_DIR=./server/uploads
MAX_FILE_SIZE_MB=5

# JWT secret — change this to any long random string before deploying
JWT_SECRET=change-this-to-a-long-random-string

# Legacy admin password (used only if not using email/password accounts)
ADMIN_PASSWORD=admin123
